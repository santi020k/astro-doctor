---
import LogoMark from '@/components/logo-mark.astro'
import Base from '@/layouts/Base.astro'

import { CATEGORY_COLORS, CATEGORY_LABELS, RULES } from '@/data/rules'
import { REACT_DOCTOR_URL } from '@/site.config'
---

<Base title="astro-doctor" description="Your agent writes bad Astro. This catches it. ESLint rules, CLI, GitHub Action and agent skills for better Astro code.">

  <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden pt-20 pb-16 md:pt-28 md:pb-24">
    <!-- Background glow orbs -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-32 left-1/2 h-[600px] w-[800px] -translate-x-1/2 rounded-full bg-[hsl(var(--brand)/0.06)] blur-[120px]"></div>
      <div class="absolute top-0 right-0 h-[400px] w-[400px] rounded-full bg-[hsl(var(--accent)/0.04)] blur-[100px]"></div>
    </div>

    <div class="container-docs relative">
      <div class="mx-auto max-w-3xl text-center">
        <!-- Badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[hsl(var(--brand)/0.3)] bg-[hsl(var(--brand-soft))] px-4 py-1.5" data-reveal>
          <span class="h-1.5 w-1.5 rounded-full bg-[hsl(var(--brand))] animate-[pulse-brand_2s_ease-in-out_infinite]"></span>
          <span class="text-xs font-medium text-[hsl(var(--brand))]">ESLint · CLI · GitHub Action · Agent Skills</span>
        </div>

        <!-- Headline -->
        <h1 class="mb-6 text-5xl font-black leading-[1.05] tracking-tight sm:text-6xl md:text-7xl" data-reveal style="animation-delay: 50ms">
          Your agent writes
          <br />
          <span class="gradient-text">bad Astro.</span>
          <br />
          This catches it.
        </h1>

        <!-- Sub-headline -->
        <p class="mb-10 text-lg text-[hsl(var(--ink-soft))] sm:text-xl leading-relaxed max-w-xl mx-auto" data-reveal style="animation-delay: 100ms">
          {RULES.length} opinionated ESLint rules for <code>.astro</code> files — performance, accessibility, security, best practices —
          with a health score, CLI, and native GitHub Action.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center" data-reveal style="animation-delay: 150ms">
          <a
            href="/docs"
            class="flex items-center justify-center gap-2 rounded-xl bg-[hsl(var(--brand))] px-6 py-3 text-sm font-semibold text-white shadow-lg hover:bg-[hsl(var(--brand-solid))] hover:shadow-[0_0_24px_hsl(var(--brand)/0.35)] transition-all duration-200 no-underline"
          >
            Get started
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a
            href="https://github.com/santi020k/astro-doctor"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 rounded-xl border border-[hsl(var(--line))] bg-[hsl(var(--surface))] px-6 py-3 text-sm font-semibold text-[hsl(var(--ink))] hover:border-[hsl(var(--brand)/0.5)] hover:bg-[hsl(var(--surface-muted))] transition-all duration-200 no-underline"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </div>

        <!-- Install snippet -->
        <div class="mt-10 inline-flex items-center gap-3 rounded-xl border border-[hsl(var(--line)/0.5)] bg-[hsl(var(--surface))] px-5 py-3 font-mono text-sm" data-reveal style="animation-delay: 200ms">
          <span class="text-[hsl(var(--ink-muted))]">$</span>
          <span class="text-[hsl(var(--brand))]">pnpm</span>
          <span class="text-[hsl(var(--ink))]">add -D @santi020k/astro-doctor</span>
          <button
            id="copy-install"
            aria-label="Copy install command"
            class="ml-2 flex h-6 w-6 items-center justify-center rounded text-[hsl(var(--ink-muted))] hover:text-[hsl(var(--brand))] transition-colors"
          >
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </button>
        </div>
      </div>

      <!-- Terminal demo -->
      <div class="mt-16 mx-auto max-w-2xl" data-reveal style="animation-delay: 250ms">
        <div class="rounded-2xl border border-[hsl(var(--line)/0.5)] bg-[hsl(var(--surface))] shadow-2xl overflow-hidden">
          <!-- Terminal header -->
          <div class="flex items-center gap-2 border-b border-[hsl(var(--line)/0.4)] px-4 py-3">
            <span class="h-3 w-3 rounded-full bg-red-500/80"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500/80"></span>
            <span class="h-3 w-3 rounded-full bg-green-500/80"></span>
            <span class="ml-3 text-xs text-[hsl(var(--ink-muted))] font-mono">astro-doctor scan</span>
          </div>
          <!-- Terminal body -->
          <div class="p-5 font-mono text-sm leading-relaxed">
            <div class="text-[hsl(var(--ink-muted))]">$ astro-doctor</div>
            <div class="mt-2 text-[hsl(var(--ink-soft))]">Scanning /my-astro-project...</div>
            <div class="mt-3 space-y-1">
              <div>
                <span class="text-red-400">✗ error</span>
                <span class="text-[hsl(var(--ink-soft))]"> src/pages/blog.astro:12 — </span>
                <span class="text-[hsl(var(--ink))]">no-missing-alt</span>
              </div>
              <div>
                <span class="text-red-400">✗ error</span>
                <span class="text-[hsl(var(--ink-soft))]"> src/components/Hero.astro:8 — </span>
                <span class="text-[hsl(var(--ink))]">no-set-html</span>
              </div>
              <div>
                <span class="text-yellow-400">⚠ warn</span>
                <span class="text-[hsl(var(--ink-soft))]">  src/components/Counter.astro:3 — </span>
                <span class="text-[hsl(var(--ink))]">no-client-load-overuse</span>
              </div>
              <div>
                <span class="text-yellow-400">⚠ warn</span>
                <span class="text-[hsl(var(--ink-soft))]">  src/pages/index.astro:24 — </span>
                <span class="text-[hsl(var(--ink))]">use-astro-image</span>
              </div>
            </div>
            <div class="mt-4 text-[hsl(var(--ink-soft))]">14 files scanned · 2 errors · 2 warnings</div>
            <div class="mt-3 flex items-center gap-3">
              <span class="text-[hsl(var(--ink-soft))]">Astro Doctor Score:</span>
              <span class="font-bold text-yellow-400">72/100 (C)</span>
              <span class="text-yellow-400">🟡</span>
            </div>
            <div class="mt-1 text-red-400 text-xs">Process exited with code 1</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Score demo ────────────────────────────────────────────────────── -->
  <section class="py-16">
    <div class="container-docs">
      <div class="mx-auto max-w-3xl text-center mb-10" data-reveal>
        <h2 class="text-3xl font-bold tracking-tight mb-3">Know exactly how healthy your codebase is</h2>
        <p class="text-[hsl(var(--ink-soft))]">Every scan produces a 0–100 health score with a letter grade, so you can set thresholds and track improvement over time.</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-3 max-w-2xl mx-auto" data-stagger="80">
        {[
          { grade: 'S', range: '100', color: 'text-purple-400', bg: 'bg-purple-500/10 border-purple-500/30' },
          { grade: 'A', range: '90–99', color: 'text-green-400', bg: 'bg-green-500/10 border-green-500/30' },
          { grade: 'B', range: '75–89', color: 'text-blue-400', bg: 'bg-blue-500/10 border-blue-500/30' },
          { grade: 'C', range: '60–74', color: 'text-yellow-400', bg: 'bg-yellow-500/10 border-yellow-500/30' },
          { grade: 'D', range: '40–59', color: 'text-orange-400', bg: 'bg-orange-500/10 border-orange-500/30' },
          { grade: 'F', range: '0–39', color: 'text-red-400', bg: 'bg-red-500/10 border-red-500/30' }
        ].map(({ grade, range, color, bg }) => (
          <div class={`flex flex-col items-center gap-2 rounded-xl border p-4 ${bg}`}>
            <span class={`text-4xl font-black ${color}`}>{grade}</span>
            <span class="text-xs text-[hsl(var(--ink-muted))]">{range}</span>
          </div>
        ))}
      </div>

      <p class="mt-6 text-center text-xs text-[hsl(var(--ink-muted))]">
        Score = max(0, 100 − (errors×10 + warnings×3) / files)
      </p>
    </div>
  </section>

  <!-- ─── Features ──────────────────────────────────────────────────────── -->
  <section class="py-16">
    <div class="container-docs">
      <div class="mx-auto max-w-3xl text-center mb-12" data-reveal>
        <h2 class="text-3xl font-bold tracking-tight mb-3">Everything you need to ship better Astro</h2>
        <p class="text-[hsl(var(--ink-soft))]">One install, multiple touch points — from your editor to your CI pipeline.</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-stagger="70">
        {[
          {
            icon: '<path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>',
            title: 'ESLint Plugin',
            desc: 'Drop-in flat-config plugin. Works with any ESLint 9 setup — standalone or alongside your existing config.'
          },
          {
            icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
            title: 'VS Code Extension',
            desc: 'Official extension for VS Code and Cursor. Real-time inline diagnostics, hover explanations, quick fixes, and a health sidebar.'
          },
          {
            icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M8 8h5M8 16h3"/>',
            title: 'CLI Scanner',
            desc: 'pnpm dlx @santi020k/astro-doctor — scan any directory, output JSON reports, and integrate into any CI pipeline.'
          },
          {
            icon: '<path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 5v5l3 3"/><circle cx="12" cy="12" r="1"/>',
            title: 'Health Score',
            desc: '0–100 score with A–F grade. Set --fail-on thresholds. Track codebase health across PRs and releases.'
          },
          {
            icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
            title: 'GitHub Action',
            desc: 'Composite action with PR diff mode — scan only changed files, post a sticky summary comment on every PR.'
          },
          {
            icon: '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>',
            title: 'JSON Reports',
            desc: 'Machine-readable output with --json. Pipe into other tools, dashboards, or custom notification systems.'
          },
          {
            icon: '<circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>',
            title: 'Agent Skills',
            desc: 'Pre-built skill files for Claude, Cursor, Copilot Workspace. Your AI agent knows the rules — and how to fix them.'
          }
        ].map(({ icon, title, desc }) => (
          <div class="panel-card p-6 flex flex-col gap-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(var(--brand-soft))]">
              <svg class="h-5 w-5 text-[hsl(var(--brand))]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={icon} />
            </div>
            <div>
              <h3 class="font-semibold text-[hsl(var(--ink))] mb-1">{title}</h3>
              <p class="text-sm text-[hsl(var(--ink-soft))] leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Rules showcase ────────────────────────────────────────────────── -->
  <section class="py-16">
    <div class="container-docs">
      <div class="mx-auto max-w-3xl text-center mb-12" data-reveal>
        <h2 class="text-3xl font-bold tracking-tight mb-3">{RULES.length} rules. Zero excuses.</h2>
        <p class="text-[hsl(var(--ink-soft))]">Each rule targets a specific class of mistake that agents and developers commonly make in Astro projects.</p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 max-w-3xl mx-auto" data-stagger="60">
        {RULES.map(rule => (
          <a
            href={`/docs/rules/${rule.slug}`}
            class="panel-card flex items-start gap-4 p-5 no-underline group"
          >
            <div class="shrink-0 mt-0.5">
              <span class:list={[
                'inline-flex items-center rounded-md px-2 py-0.5 text-xs font-semibold',
                rule.severity === 'error' ? 'bg-red-500/10 text-red-400 border border-red-500/20' : 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20'
              ]}
              >
                {rule.severity}
              </span>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="font-mono text-sm font-semibold text-[hsl(var(--ink))] group-hover:text-[hsl(var(--brand))] transition-colors">
                  {rule.id}
                </span>
                <span class:list={['inline-flex items-center rounded px-1.5 py-0.5 text-xs font-medium', CATEGORY_COLORS[rule.category]]}>
                  {CATEGORY_LABELS[rule.category]}
                </span>
              </div>
              <p class="text-sm text-[hsl(var(--ink-soft))]">{rule.description}</p>
            </div>
            <svg class="h-4 w-4 shrink-0 text-[hsl(var(--ink-muted))] group-hover:text-[hsl(var(--brand))] transition-colors mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a
          href="/docs/rules"
          class="inline-flex items-center gap-2 text-sm text-[hsl(var(--brand))] hover:text-[hsl(var(--accent))] transition-colors"
        >
          View all rules with examples
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── Quick start ───────────────────────────────────────────────────── -->
  <section class="py-16">
    <div class="container-docs">
      <div class="mx-auto max-w-2xl" data-reveal>
        <div class="section-shell">
          <h2 class="text-2xl font-bold mb-2 text-[hsl(var(--ink))]">Up and running in 2 minutes</h2>
          <p class="text-[hsl(var(--ink-soft))] mb-8 text-sm">Install once, catch issues everywhere.</p>

          <ol class="space-y-6">
            <li class="flex gap-4">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[hsl(var(--brand))] text-white text-xs font-bold">1</span>
              <div class="min-w-0">
                <p class="text-sm font-medium text-[hsl(var(--ink))] mb-2">Install the package</p>
                <pre class="!mt-0 !text-xs"><code>pnpm add -D @santi020k/astro-doctor</code></pre>
              </div>
            </li>

            <li class="flex gap-4">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[hsl(var(--brand))] text-white text-xs font-bold">2</span>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-[hsl(var(--ink))] mb-2">Add to your ESLint config</p>
                <pre class="!mt-0 !text-xs"><code>{`// eslint.config.js
import astroDoctorPlugin from '@santi020k/eslint-plugin-astro-doctor'

export default [
  astroDoctorPlugin.configs.recommended,
]`}
                </code>
                </pre>
              </div>
            </li>

            <li class="flex gap-4">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[hsl(var(--brand))] text-white text-xs font-bold">3</span>
              <div class="min-w-0">
                <p class="text-sm font-medium text-[hsl(var(--ink))] mb-2">Scan your project</p>
                <pre class="!mt-0 !text-xs"><code>pnpm astro-doctor</code></pre>
              </div>
            </li>
          </ol>

          <div class="mt-8 flex gap-3">
            <a
              href="/docs/quick-start"
              class="flex items-center gap-2 rounded-lg bg-[hsl(var(--brand))] px-4 py-2.5 text-sm font-semibold text-white hover:bg-[hsl(var(--brand-solid))] transition-colors no-underline"
            >
              Full quick start guide
            </a>
            <a
              href="/docs/installation"
              class="flex items-center gap-2 rounded-lg border border-[hsl(var(--line))] px-4 py-2.5 text-sm font-medium text-[hsl(var(--ink))] hover:bg-[hsl(var(--surface-muted))] transition-colors no-underline"
            >
              Installation options
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── GitHub Action showcase ────────────────────────────────────────── -->
  <section class="py-16">
    <div class="container-docs">
      <div class="grid gap-12 lg:grid-cols-2 items-center max-w-5xl mx-auto" data-reveal>
        <div>
          <span class="mb-3 inline-flex items-center rounded-full bg-[hsl(var(--brand-soft))] px-3 py-1 text-xs font-medium text-[hsl(var(--brand))]">
            CI / CD
          </span>
          <h2 class="text-3xl font-bold tracking-tight mb-4 text-[hsl(var(--ink))]">
            PR-aware scanning with sticky comments
          </h2>
          <p class="text-[hsl(var(--ink-soft))] mb-6 leading-relaxed">
            The composite GitHub Action scans only the files changed in a pull request and posts a sticky summary comment with the score and all diagnostics. Updated on every push, never duplicated.
          </p>
          <ul class="space-y-2">
            {[
              'Scans only changed Astro Doctor files with diff-only: true',
              'Posts and updates a single sticky PR comment',
              'Outputs score, errors, warnings as Action step outputs',
              'Configurable fail-on threshold (error / warning / off)'
            ].map(item => (
              <li class="flex items-start gap-2 text-sm text-[hsl(var(--ink-soft))]">
                <svg class="h-4 w-4 shrink-0 mt-0.5 text-[hsl(var(--brand))]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <a
            href="/docs/github-action"
            class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-[hsl(var(--brand))] hover:text-[hsl(var(--accent))] transition-colors"
          >
            GitHub Action docs
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="rounded-2xl border border-[hsl(var(--line)/0.5)] bg-[hsl(var(--surface))] overflow-hidden">
          <div class="border-b border-[hsl(var(--line)/0.4)] px-4 py-3">
            <span class="text-xs font-medium text-[hsl(var(--ink-muted))]">.github/workflows/astro-doctor.yml</span>
          </div>
          <pre class="!border-none !rounded-none !bg-transparent !p-5 !text-xs overflow-auto"><code>{`name: Astro Doctor
on:
  pull_request:
    paths: ['**/*.astro']

jobs:
  scan:
    runs-on: ubuntu-latest
    permissions:
      pull-requests: write
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: santi020k/astro-doctor@v1
        with:
          diff-only: true
          comment: true
          fail-on: error`}
          </code>
          </pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Agent skills ──────────────────────────────────────────────────── -->
  <section class="py-16">
    <div class="container-docs">
      <div class="max-w-3xl mx-auto text-center mb-10" data-reveal>
        <span class="mb-3 inline-flex items-center rounded-full bg-[hsl(var(--brand-soft))] px-3 py-1 text-xs font-medium text-[hsl(var(--brand))]">
          AI-native
        </span>
        <h2 class="text-3xl font-bold tracking-tight mb-3 text-[hsl(var(--ink))]">Built for the age of coding agents</h2>
        <p class="text-[hsl(var(--ink-soft))]">
          Agent skills teach your AI assistant every rule — what to avoid, why, and how to fix it.
          Install once with <code>astro-doctor install</code>.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-3 max-w-3xl mx-auto" data-stagger="70">
        {[
          {
            name: 'astro-rules',
            desc: `All ${RULES.length} rules with before/after examples your agent can reference.`,
            compatible: ['Claude', 'Cursor', 'Copilot']
          },
          {
            name: 'astro-performance',
            desc: 'Islands architecture, image optimization, View Transitions, Server Islands.',
            compatible: ['Claude', 'Cursor', 'Copilot']
          },
          {
            name: 'add-rule',
            desc: 'Step-by-step TDD workflow for contributing new rules to the plugin.',
            compatible: ['Claude', 'Cursor']
          }
        ].map(({ name, desc, compatible }) => (
          <div class="panel-card p-5 flex flex-col gap-3">
            <div class="flex items-center gap-2">
              <div class="h-8 w-8 rounded-lg bg-[hsl(var(--brand-soft))] flex items-center justify-center text-[hsl(var(--brand))]">
