<script>
  const btn = document.getElementById('copy-install')
  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText('pnpm add -D @santi020k/astro-doctor')
    const icon = btn.querySelector('svg')
    if (icon) {
      icon.innerHTML = '<polyline points="20 6 9 17 4 12"/>'
      setTimeout(() => {
        icon.innerHTML = '<rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>'
      }, 1500)
    }
  })
</script>
