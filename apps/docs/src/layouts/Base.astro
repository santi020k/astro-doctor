---
import Footer from '@/components/Footer.astro'
import Nav from '@/components/Nav.astro'

import '@/styles/global.css'

interface Props {
  title: string
  description?: string
  ogImage?: string
  noIndex?: boolean
}

const SITE_URL = 'https://doctor.santi020k.com'

const {
  title,
  description = 'astro-doctor — ESLint rules and CLI for finding common Astro mistakes. Score your codebase, scan in CI, and ship better Astro apps.',
  ogImage = `${SITE_URL}/og.svg`,
  noIndex = false
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE_URL).href
const fullTitle = title === 'astro-doctor' ? title : `${title} · astro-doctor`

const websiteJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website`,
  name: 'astro-doctor',
  url: `${SITE_URL}/`,
  description,
  inLanguage: 'en',
  author: {
    '@type': 'Person',
    name: 'Santiago Molina',
    alternateName: 'santi020k',
    url: 'https://santi020k.com'
  }
})

const softwareJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'astro-doctor',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  description: 'ESLint plugin, CLI, and GitHub Action for diagnosing Astro codebases.',
  url: `${SITE_URL}/`,
  author: {
    '@type': 'Person',
    name: 'Santiago Molina',
    url: 'https://santi020k.com'
  },
  license: 'https://opensource.org/licenses/MIT',
  codeRepository: 'https://github.com/santi020k/astro-doctor'
})
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Santiago Molina" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#7c3aed" />
    {noIndex ?
(
      <meta name="robots" content="noindex, nofollow" />
    ) :
(
      <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    )}

    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${fullTitle} — astro-doctor`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="astro-doctor" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@santi020k" />
    <meta name="twitter:creator" content="@santi020k" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${fullTitle} — astro-doctor`} />

    <!-- Theme init (inline to prevent flash) -->
    <script is:inline>
      ;(function () {
        const saved = localStorage.getItem('theme')
        const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        document.documentElement.setAttribute('data-theme', saved ?? preferred)
      })()
    </script>

    <!-- Structured data -->
    <script type="application/ld+json" is:inline set:html={websiteJsonLd} />
    <script type="application/ld+json" is:inline set:html={softwareJsonLd} />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Scroll reveal -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible')
              // Apply stagger delay to children
              const stagger = (entry.target as HTMLElement).dataset['stagger']
              if (stagger) {
                const delay = Number(stagger)
                const children = entry.target.children
                for (let i = 0; i < children.length; i++) {
                  ;(children[i] as HTMLElement).style.transitionDelay = `${i * delay}ms`
                }
              }
              observer.unobserve(entry.target)
            }
          }
        },
        { threshold: 0.08 },
      )

      for (const el of document.querySelectorAll('[data-reveal], [data-stagger]')) {
        observer.observe(el)
      }
    </script>
  </body>
</html>
