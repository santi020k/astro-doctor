---
import DocsSidebar from '@/components/DocsSidebar.astro'

import { DOCS_NAV } from '@/data/nav'

import Base from './Base.astro'

interface Props {
  title: string
  description?: string
  editPath?: string
}

const { title, description, editPath } = Astro.props
// Find prev/next pages for navigation
const allPages = DOCS_NAV.flatMap(section => section.items)
const currentPath = Astro.url.pathname.replace(/\/$/, '')
const currentIndex = allPages.findIndex(p => p.href === currentPath)
const prevPage = currentIndex > 0 ? allPages[currentIndex - 1] : undefined
const nextPage = currentIndex < allPages.length - 1 ? allPages[currentIndex + 1] : undefined
---

<Base title={title} description={description}>
  <div class="container-docs py-8 lg:py-12">
    <div class="flex gap-12">
      <DocsSidebar />

      <!-- Main content -->
      <div class="min-w-0 flex-1">
        <article class="prose max-w-none">
          <slot />
        </article>

        <!-- Pagination -->
        {(prevPage ?? nextPage) && (
          <nav
            class="mt-12 flex gap-4 border-t border-[hsl(var(--line)/0.4)] pt-8"
            aria-label="Pagination"
          >
            {prevPage && (
              <a
                href={prevPage.href}
                class="flex flex-col gap-1 rounded-xl border border-[hsl(var(--line)/0.4)] px-5 py-4 hover:border-[hsl(var(--brand)/0.4)] hover:bg-[hsl(var(--surface-muted))] transition-colors group no-underline flex-1"
              >
                <span class="text-xs text-[hsl(var(--ink-muted))]">← Previous</span>
                <span class="text-sm font-medium text-[hsl(var(--ink))] group-hover:text-[hsl(var(--brand))] transition-colors">
                  {prevPage.label}
                </span>
              </a>
            )}
            {nextPage && (
              <a
                href={nextPage.href}
                class="flex flex-col gap-1 rounded-xl border border-[hsl(var(--line)/0.4)] px-5 py-4 hover:border-[hsl(var(--brand)/0.4)] hover:bg-[hsl(var(--surface-muted))] transition-colors group no-underline ml-auto text-right flex-1"
              >
                <span class="text-xs text-[hsl(var(--ink-muted))]">Next →</span>
                <span class="text-sm font-medium text-[hsl(var(--ink))] group-hover:text-[hsl(var(--brand))] transition-colors">
                  {nextPage.label}
                </span>
              </a>
            )}
          </nav>
        )}

        <!-- Edit on GitHub -->
        {editPath && (
          <div class="mt-8 text-right">
            <a
              href={`https://github.com/santi020k/astro-doctor/edit/main/${editPath}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-[hsl(var(--ink-muted))] hover:text-[hsl(var(--brand))] transition-colors"
            >
              Edit this page on GitHub ↗
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</Base>
