---
import DocsSidebar from '@/components/DocsSidebar.astro'

import { DOCS_NAV } from '@/data/nav'
import { getOgImagePath } from '@/site.config'

import Base from './Base.astro'

interface Props {
  title: string
  description?: string
  editPath?: string
}

const { title, description, editPath } = Astro.props
const ogImage = getOgImagePath(Astro.url.pathname)
// Find prev/next pages for navigation
const allPages = DOCS_NAV.flatMap(section => section.items)
const currentPath = Astro.url.pathname.replace(/\/$/, '')
const currentIndex = allPages.findIndex(p => p.href === currentPath)
const prevPage = currentIndex > 0 ? allPages[currentIndex - 1] : undefined
const nextPage = currentIndex < allPages.length - 1 ? allPages[currentIndex + 1] : undefined
---

<Base title={title} description={description} ogImage={ogImage} ogType="article">
  <div class="
    container-docs py-8
    lg:py-12
  "
  >
    <div class="flex gap-12">
      <DocsSidebar />

      <!-- Main content -->
      <div class="min-w-0 flex-1">
        <article class="prose max-w-none">
          <slot />
        </article>

        <!-- Pagination -->
        {(prevPage ?? nextPage) && (
          <nav
            class="mt-12 flex gap-4 border-t border-[hsl(var(--line)/0.4)] pt-8"
            aria-label="Pagination"
          >
            {prevPage && (
              <a
                href={prevPage.href}
                class="
                  group flex flex-1 flex-col gap-1 rounded-xl border
                  border-[hsl(var(--line)/0.4)] px-5 py-4 no-underline
                  transition-colors
                  hover:border-[hsl(var(--brand)/0.4)]
                  hover:bg-[hsl(var(--surface-muted))]
                "
              >
                <span class="text-xs text-[hsl(var(--ink-muted))]">← Previous</span>
                <span class="
                  text-sm font-medium text-[hsl(var(--ink))] transition-colors
                  group-hover:text-[hsl(var(--brand))]
                "
                >
                  {prevPage.label}
                </span>
              </a>
            )}
            {nextPage && (
              <a
                href={nextPage.href}
                class="
                  group ml-auto flex flex-1 flex-col gap-1 rounded-xl border
                  border-[hsl(var(--line)/0.4)] px-5 py-4 text-right
                  no-underline transition-colors
                  hover:border-[hsl(var(--brand)/0.4)]
                  hover:bg-[hsl(var(--surface-muted))]
                "
              >
                <span class="text-xs text-[hsl(var(--ink-muted))]">Next →</span>
                <span class="
                  text-sm font-medium text-[hsl(var(--ink))] transition-colors
                  group-hover:text-[hsl(var(--brand))]
                "
                >
                  {nextPage.label}
                </span>
              </a>
            )}
          </nav>
        )}

        <!-- Edit on GitHub -->
        {editPath && (
          <div class="mt-8 text-right">
            <a
              href={`https://github.com/santi020k/astro-doctor/edit/main/${editPath}`}
              target="_blank"
              rel="noopener noreferrer"
              class="
                text-xs text-[hsl(var(--ink-muted))] transition-colors
                hover:text-[hsl(var(--brand))]
              "
            >
              Edit this page on GitHub ↗
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</Base>
