---
import LogoMark from '@/components/logo-mark.astro'

import { AUTHOR, AUTHOR_URL, CHANGELOG_URL, GITHUB_URL, NPM_URL, REACT_DOCTOR_URL, SITE_NAME, SITE_TAGLINE } from '@/site.config'

const year = new Date().getFullYear()
---

<footer class="mt-24 border-t border-[hsl(var(--line)/0.4)] py-12">
  <div class="container-docs">
    <div class="
      flex flex-col gap-8
      sm:flex-row sm:justify-between
    "
    >
      <!-- Brand -->
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-2.5">
          <LogoMark class="size-7 rounded-md" />
          <span class="font-semibold text-[hsl(var(--ink))]">{SITE_NAME}</span>
        </div>
        <p class="max-w-xs text-sm text-[hsl(var(--ink-muted))]">
          {SITE_TAGLINE}
        </p>
        <p class="text-xs text-[hsl(var(--ink-muted))]">
          Inspired by <a
href={REACT_DOCTOR_URL}
target="_blank"
rel="noopener noreferrer"
class="
  transition-colors
  hover:text-[hsl(var(--brand))]
"
                      >react-doctor</a>
        </p>
      </div>

      <!-- Links -->
      <div class="
        grid grid-cols-2 gap-8
        sm:grid-cols-3
      "
      >
        <div class="flex flex-col gap-2">
          <h3 class="
            text-xs font-semibold tracking-wider text-[hsl(var(--ink-muted))]
            uppercase
          "
          >Docs</h3>
          <a
href="/docs"
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >Introduction</a>
          <a
href="/docs/installation"
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >Installation</a>
          <a
href="/docs/quick-start"
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >Quick Start</a>
          <a
href="/docs/configuration"
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >Configuration</a>
        </div>

        <div class="flex flex-col gap-2">
          <h3 class="
            text-xs font-semibold tracking-wider text-[hsl(var(--ink-muted))]
            uppercase
          "
          >Reference</h3>
          <a
href="/docs/rules"
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >Rules</a>
          <a
href="/docs/cli"
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >CLI</a>
          <a
href="/docs/github-action"
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >GitHub Action</a>
          <a
href="/docs/agent-skills"
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >Agent Skills</a>
        </div>

        <div class="flex flex-col gap-2">
          <h3 class="
            text-xs font-semibold tracking-wider text-[hsl(var(--ink-muted))]
            uppercase
          "
          >Project</h3>
          <a
href={GITHUB_URL}
target="_blank"
rel="noopener noreferrer"
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >GitHub</a>
          <a
href={NPM_URL}
target="_blank"
rel="noopener noreferrer"
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >npm</a>
          <a
href={CHANGELOG_URL}
class="
  text-sm text-[hsl(var(--ink-soft))] transition-colors
  hover:text-[hsl(var(--brand))]
"
          >Changelog</a>
        </div>
      </div>
    </div>

    <div class="
      mt-10 flex flex-col items-center justify-between gap-3 border-t
      border-[hsl(var(--line)/0.4)] pt-6
      sm:flex-row
    "
    >
      <p class="text-xs text-[hsl(var(--ink-muted))]">
        &copy; {year} <a
href={AUTHOR_URL}
target="_blank"
rel="noopener noreferrer"
class="
  transition-colors
  hover:text-[hsl(var(--brand))]
"
                      >{AUTHOR}</a>. MIT License.
      </p>
      <p class="text-xs text-[hsl(var(--ink-muted))]">
        Built with <a
href="https://astro.build"
target="_blank"
rel="noopener noreferrer"
class="
  transition-colors
  hover:text-[hsl(var(--brand))]
"
                   >Astro</a> · Deployed on <a
href="https://pages.cloudflare.com"
target="_blank"
rel="noopener noreferrer"
class="
  transition-colors
  hover:text-[hsl(var(--brand))]
"
                                            >Cloudflare Pages</a>
      </p>
    </div>
  </div>
</footer>
