---
import { DOCS_NAV } from '@/data/nav'

const currentPath = Astro.url.pathname.replace(/\/$/, '')
---

<aside class="
  hidden w-56 shrink-0
  lg:block
"
>
  <nav class="sticky top-20 flex flex-col gap-6" aria-label="Documentation navigation">
    {DOCS_NAV.map(section => (
      <div>
        <h2 class="
          mb-2 px-3 text-xs font-semibold tracking-wider
          text-[hsl(var(--ink-muted))] uppercase
        "
        >
          {section.title}
        </h2>
        <ul class="space-y-0.5">
          {section.items.map(item => {
            const isActive = currentPath === item.href || currentPath === item.href + '/index'

            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    `
                      flex items-center justify-between rounded-md px-3 py-1.5
                      text-sm transition-colors
                    `,
                    isActive ?
                      `
                        bg-[hsl(var(--brand-soft))] font-medium
                        text-[hsl(var(--brand))]
                      ` :
                      `
                        text-[hsl(var(--ink-soft))]
                        hover:bg-[hsl(var(--surface-muted))]
                        hover:text-[hsl(var(--ink))]
                      `
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  <span class="truncate">{item.label}</span>
                  {item.badge && (
                    <span class="
                      ml-2 shrink-0 rounded-sm bg-[hsl(var(--brand-soft))]
                      px-1.5 py-0.5 text-[10px] font-semibold
                      text-[hsl(var(--brand))]
                    "
                    >
                      {item.badge}
                    </span>
                  )}
                </a>
              </li>
            )
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>
