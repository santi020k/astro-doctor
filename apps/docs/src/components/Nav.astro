---
import LogoMark from '@/components/logo-mark.astro'

import { GITHUB_URL, NPM_URL, SITE_NAME } from '@/site.config'

const currentPath = Astro.url.pathname
const isDocsActive = currentPath.startsWith('/docs')
---

<header class="
  sticky top-0 z-50 w-full border-b border-[hsl(var(--line)/0.4)]
  bg-[hsl(var(--theme-bg)/0.85)] backdrop-blur-md
"
>
  <nav class="container-docs flex h-14 items-center justify-between gap-4">
    <!-- Logo -->
    <a
href="/"
class="
  group flex items-center gap-2.5 no-underline
  hover:no-underline
"
    >
      <LogoMark
        class="
          size-8 rounded-lg shadow-md transition-shadow
          group-hover:shadow-[0_0_16px_hsl(var(--brand)/0.5)]
        "
      />
      <span class="font-semibold tracking-tight text-[hsl(var(--ink))]">
        {SITE_NAME}
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="
      hidden items-center gap-1
      md:flex
    "
    >
      <a
        href="/docs"
        class:list={[
          'rounded-md px-3 py-1.5 text-sm transition-colors',
          isDocsActive ?
            'bg-[hsl(var(--brand-soft))] font-medium text-[hsl(var(--brand))]' :
            `
              text-[hsl(var(--ink-soft))]
              hover:bg-[hsl(var(--surface-muted))] hover:text-[hsl(var(--ink))]
            `
        ]}
      >
        Docs
      </a>
      <a
        href="/docs/rules"
        class="
          rounded-md px-3 py-1.5 text-sm text-[hsl(var(--ink-soft))]
          transition-colors
          hover:bg-[hsl(var(--surface-muted))] hover:text-[hsl(var(--ink))]
        "
      >
        Rules
      </a>
      <a
        href="/docs/cli"
        class="
          rounded-md px-3 py-1.5 text-sm text-[hsl(var(--ink-soft))]
          transition-colors
          hover:bg-[hsl(var(--surface-muted))] hover:text-[hsl(var(--ink))]
        "
      >
        CLI
      </a>
    </div>

    <!-- Right side actions -->
    <div class="flex items-center gap-2">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle color scheme"
        class="
          flex size-8 items-center justify-center rounded-md
          text-[hsl(var(--ink-soft))] transition-colors
          hover:bg-[hsl(var(--surface-muted))] hover:text-[hsl(var(--ink))]
        "
      >
        <svg class="dark-icon hidden size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg class="light-icon size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
      </button>

      <!-- GitHub link -->
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View on GitHub"
        class="
          flex size-8 items-center justify-center rounded-md
          text-[hsl(var(--ink-soft))] transition-colors
          hover:bg-[hsl(var(--surface-muted))] hover:text-[hsl(var(--ink))]
        "
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>

      <!-- npm badge -->
      <a
        href={NPM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="
          hidden h-8 items-center gap-1.5 rounded-md bg-[hsl(var(--brand))] px-3
          text-xs font-semibold text-white no-underline transition-colors
          hover:bg-[hsl(var(--brand-solid))]
          sm:flex
        "
      >
        npm install
      </a>
    </div>
  </nav>
</header>

<script>
  const html = document.documentElement
  const btn = document.getElementById('theme-toggle')
  const darkIcon = document.querySelector('.dark-icon') as HTMLElement | null
  const lightIcon = document.querySelector('.light-icon') as HTMLElement | null

  const getTheme = () =>
    html.getAttribute('data-theme') ??
    (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')

  const applyTheme = (theme: string) => {
    html.setAttribute('data-theme', theme)
    localStorage.setItem('theme', theme)
    if (darkIcon && lightIcon) {
      darkIcon.classList.toggle('hidden', theme === 'light')
      lightIcon.classList.toggle('hidden', theme === 'dark')
    }
  }

  // Init
  applyTheme(localStorage.getItem('theme') ?? getTheme())

  btn?.addEventListener('click', () => {
    applyTheme(getTheme() === 'dark' ? 'light' : 'dark')
  })
</script>
