{
  "name": "@santi020k/astro-doctor-docs",
  "version": "0.0.0",
  "private": true,
  "description": "Documentation website for astro-doctor",
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/generate-og-images.mjs && astro build",
    "generate:og": "node scripts/generate-og-images.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "typecheck": "astro check",
    "lint": "eslint . --no-warn-ignored",
    "lint:fix": "eslint . --fix --no-warn-ignored",
    "clean": "rm -rf dist .astro node_modules"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.8",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@resvg/resvg-js": "^2.6.2",
    "@santi020k/eslint-config-basic": "latest",
    "eslint": "^10.5.0",
    "satori": "^0.12.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.103.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
