{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  },
  "ignore": ["apps/docs/**"],
  "ignoreDependencies": ["wrangler"],
  "workspaces": {

    "packages/eslint-plugin-astro-doctor": {
      "project": ["src/**/*.ts"]
    },
    "packages/astro-doctor": {
      "entry": ["bin/**/*.ts", "src/cli.ts"],
      "project": ["src/**/*.ts", "bin/**/*.ts"]
    },
    "packages/vscode-astro-doctor": {

      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@santi020k/astro-doctor", "@santi020k/eslint-plugin-astro-doctor", "@types/vscode"]
    }
  }
}
