{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "paths": {
      "vscode-languageserver/node.js": ["./node_modules/vscode-languageserver/node.d.ts"],
