{
  "name": "@santi020k/astro-doctor",
  "version": "1.0.2",
  "description": "Your agent writes bad Astro. This catches it.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "bin": {
    "astro-doctor": "./dist/bin/astro-doctor.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src tests bin --cache --no-warn-ignored",
    "lint:fix": "eslint src tests bin --cache --fix --no-warn-ignored",
    "check:exports": "attw --pack . --profile esm-only",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@santi020k/eslint-plugin-astro-doctor": "workspace:*",
    "astro-eslint-parser": "catalog:",
    "confbox": "catalog:",
    "eslint": "catalog:",
    "glob": "catalog:",
    "jiti": "catalog:",
    "vscode-languageserver": "catalog:",
    "vscode-languageserver-textdocument": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/santi020k/astro-doctor.git",
    "directory": "packages/astro-doctor"
  },
  "homepage": "https://github.com/santi020k/astro-doctor#readme",
  "bugs": {
    "url": "https://github.com/santi020k/astro-doctor/issues"
  },
  "keywords": [
    "astro",
    "linter",
    "cli",
    "accessibility",
    "performance",
    "security",
    "agents"
  ],
  "author": "santi020k",
  "license": "MIT"
}
