{
  "name": "vscode-astro-doctor",
  "displayName": "Astro Doctor",
  "version": "1.0.0",
  "private": true,
  "sponsor": {
    "url": "https://github.com/sponsors/santi020k"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/santi020k"
  },
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#f97316",
    "theme": "light"
  },
  "description": "Astro Doctor diagnostics, hovers, and quick fixes in your editor.",
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "publisher": "santi020k",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node scripts/build.cjs",
    "typecheck": "tsc --noEmit",
    "dev": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js --watch=forever",
    "package": "pnpm run build && node scripts/vsce-package.cjs",
    "publish:ext": "pnpm run package && pnpm run publish:vsce && pnpm run publish:ovsx",
    "publish:vsce": "pnpm dlx @vscode/vsce publish -i astro-doctor.vsix --skip-duplicate --pat \"$VSCE_PAT\"",
    "publish:ovsx": "pnpm dlx ovsx --pat \"$OVSX_PAT\" publish astro-doctor.vsix --skip-duplicate",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:watch": "vitest --config vitest.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "vscode-languageclient": "catalog:"
  },
  "devDependencies": {
    "@santi020k/astro-doctor": "workspace:*",
    "@santi020k/eslint-plugin-astro-doctor": "workspace:*",
    "@types/node": "catalog:",
    "@types/vscode": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "contributes": {
    "commands": [
      {
        "command": "astro-doctor.scanWorkspace",
        "title": "Astro Doctor: Scan Workspace"
      },
      {
        "command": "astro-doctor.scanFile",
        "title": "Astro Doctor: Scan Current File"
      },
      {
        "command": "astro-doctor.fixAll",
        "title": "Astro Doctor: Suppress All Issues in File"
      },
      {
        "command": "astro-doctor.restart",
        "title": "Astro Doctor: Restart Server"
      },
      {
        "command": "astro-doctor.showOutput",
        "title": "Astro Doctor: Show Output"
      },
      {
        "command": "astro-doctor.openDocs",
        "title": "Astro Doctor: Open Documentation"
      }
    ],
    "configuration": {
      "title": "Astro Doctor",
      "properties": {
        "astroDoctor.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Astro Doctor diagnostics, hovers, and quick fixes."
        },
        "astroDoctor.serverPath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Optional path to the astro-doctor executable. When empty, local development uses the workspace install first; production uses the bundled language server first."
        },
        "astroDoctor.scanOnType": {
          "type": "boolean",
          "default": true,
          "description": "Re-scan files live as you type (from the unsaved buffer). Disable to scan only on open and save."
        },
        "astroDoctor.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "scope": "window",
          "description": "Trace the communication between the editor and the Astro Doctor language server."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "astro-doctor",
          "title": "Astro Doctor",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "astro-doctor": [
        {
          "type": "webview",
          "id": "astroDoctor.sidebar",
          "name": "Health Report",
          "icon": "resources/icon.svg"
        }
      ]
    }
  },
  "activationEvents": [
    "onLanguage:astro"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.13.0",
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/santi020k/astro-doctor.git",
    "directory": "packages/vscode-astro-doctor"
  },
  "homepage": "https://doctor.santi020k.com",
  "bugs": {
    "url": "https://github.com/santi020k/astro-doctor/issues"
  },
  "keywords": [
    "astro",
    "diagnostics",
    "lint",
    "lsp",
    "astro-doctor",
    "performance",
    "accessibility",
    "security"
  ],
  "author": {
    "name": "Santiago Molina",
    "url": "https://santi020k.com"
  },
  "license": "MIT"
}
