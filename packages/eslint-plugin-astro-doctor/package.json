{
  "name": "@santi020k/eslint-plugin-astro-doctor",
  "version": "1.0.0",
  "description": "ESLint plugin for Astro Doctor: diagnose Astro codebases for performance, accessibility, security, and best-practice issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src tests --cache --no-warn-ignored",
    "lint:fix": "eslint src tests --cache --fix --no-warn-ignored",
    "check:exports": "attw --pack . --profile esm-only",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "astro-eslint-parser": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/santi020k/astro-doctor.git",
    "directory": "packages/eslint-plugin-astro-doctor"
  },
  "homepage": "https://github.com/santi020k/astro-doctor#readme",
  "bugs": {
    "url": "https://github.com/santi020k/astro-doctor/issues"
  },
  "keywords": [
    "astro",
    "eslint",
    "eslint-plugin",
    "linter",
    "accessibility",
    "performance",
    "security"
  ],
  "author": "santi020k",
  "license": "MIT"
}
