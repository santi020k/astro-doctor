{
  "name": "@astro-doctor/root",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test",
    "test:run": "turbo run test --filter=!@astro-doctor/root",
    "lint": "eslint . --cache --no-warn-ignored",
    "lint:fix": "eslint . --cache --fix --no-warn-ignored",
    "ok": "pnpm install --reporter=silent && turbo run build && turbo run test && pnpm run lint && turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.5",
    "@santi020k/eslint-config-basic": "latest",
    "@types/node": "^22.15.32",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts,astro}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "packageManager": "pnpm@9.15.4"
}
