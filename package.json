{
  "name": "@santi020k/astro-doctor-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "pnpm run lint:repo && turbo run lint",
    "lint:repo": "eslint . --cache --no-warn-ignored",
    "lint:fix": "pnpm run lint:repo:fix && turbo run lint:fix",
    "lint:repo:fix": "eslint . --cache --fix --no-warn-ignored",
    "lint:spell": "cspell \"**\" --gitignore --cache --show-suggestions --show-context",
    "lint:knip": "knip",
    "ok": "pnpm install --reporter=silent && turbo run build && turbo run test && pnpm run lint:repo && turbo run lint && turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "check:exports": "turbo run check:exports",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "commit": "cz"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@santi020k/eslint-config-basic": "catalog:",
    "@types/node": "catalog:",
    "commitizen": "catalog:",
    "cspell": "catalog:",
    "cz-conventional-changelog": "catalog:",
    "eslint": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "wrangler": "^4.103.0"
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts,astro}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "packageManager": "pnpm@10.34.3"
}
