# GitHub Personal Access Token — used by the release workflow to create
# GitHub Releases and push changelog commits. Requires `repo` scope.
PA_TOKEN=

# npm Access Token — used by the publish workflow to publish
# @santi020k/astro-doctor and @santi020k/eslint-plugin-astro-doctor to npm.
# Generate at https://www.npmjs.com/settings/<user>/tokens
NPM_TOKEN=

# Turbo Remote Cache — speeds up CI by sharing build artifacts across runs.
# Get a token at https://vercel.com/docs/monorepos/remote-caching
TURBO_TOKEN=
TURBO_TEAM=

# Turbo optimisation
TURBO_CONCURRENCY=10
TURBO_REMOTE_CACHE_TIMEOUT=30

# Cloudflare Pages — used by the deploy-docs workflow to publish the docs site.
# CLOUDFLARE_API_TOKEN: create an API token at https://dash.cloudflare.com/profile/api-tokens
#   (use the "Edit Cloudflare Workers" template or a custom token with Pages:Edit permission).
# CLOUDFLARE_ACCOUNT_ID: found in the right-hand sidebar of any Cloudflare dashboard page.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# VS Code extension runtime mode — controls whether the extension connects to the
# local dev LSP server or the published production server.
# Valid values: "local" | "production"
ASTRO_DOCTOR_EXTENSION_ENV=

# VS Code Marketplace Personal Access Token
# Used to automatically publish the VS Code extension
VSCE_PAT=

# Open VSX Registry Personal Access Token
# Used to automatically publish the extension to open-vsx.org
OVSX_PAT=
